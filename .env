RABBITMQ_BIND_IP=192.168.242.1
RABBITMQ_AMQP_HOST_PORT=5671
RABBITMQ_MGMT_BIND=127.0.0.1
RABBITMQ_MGMT_HOST_PORT=15672

# Host path to TLS material (each dir should have ca.pem, server.pem, server.key). Examples: ./certs  or  ./certs/site-b
RABBITMQ_CERTS_DIR=./certs

# Broker login (passed into the container; also used by example_usage.py). Change the password before production.
# These are applied on FIRST start only (empty rabbitmq_data volume). If you change them later, use rabbitmqctl or the UI, or remove the volume (data loss).
RABBITMQ_DEFAULT_USER=psadmin
RABBITMQ_DEFAULT_PASS=admin12.12
RABBITMQ_DEFAULT_VHOST=/